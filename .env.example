# ─────────────────────────────────────────────────────────────
# MafiaLife — Environment Variables
#
# LOCAL DEVELOPMENT:
#   Copy this file to .env.local (git-ignored) and fill in values.
#   Run: cp .env.example .env.local
#
# VERCEL:
#   Add these as Environment Variables in:
#   Vercel Dashboard → Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Required: Supabase Project URL ────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# ── Required: Supabase Anon Key ───────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API → anon public
# Safe to expose to the browser (used in Vite frontend build)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Feature Flags ─────────────────────────────────────────────
#
# VITE_ENABLE_DEV_TOOLS
#   Controls: DEV role switcher, DEV banners, DEV nav items,
#             skip buttons, debug selectors, /jobs-admin, /world-admin
#   Default: true in local dev (import.meta.env.DEV), false in production
#   Override: set to "true" on staging/preview to enable dev tools there
#
# VITE_ENABLE_DEV_TOOLS=false

# VITE_ENABLE_ADMIN_TOOLS
#   Controls: Admin Panel (/admin), Rank Progression (/progression)
#   Default: true in local dev, false in production
#   Override: set to "true" on staging/preview to enable admin panel
#
# VITE_ENABLE_ADMIN_TOOLS=false

# ── Optional: Force mock data ─────────────────────────────────
#   Default: uses Supabase if configured, falls back to mock if not
#   Not normally needed — the app auto-detects mock mode
#
# VITE_USE_MOCK_DATA=false

# ── Optional: Service Role Key (server-side/scripts only) ─────
# Found in: Supabase Dashboard → Project Settings → API → service_role
# NEVER expose to the browser — only use in scripts/migrations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Notes ─────────────────────────────────────────────────────
# If VITE_SUPABASE_URL is missing or set to the placeholder value,
# the app runs in MOCK MODE: all data is in-memory, auth is bypassed,
# and the prototype is accessible without a real Supabase project.
# Players will go through onboarding on every fresh session in mock mode.
