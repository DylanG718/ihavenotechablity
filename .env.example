# ─────────────────────────────────────────────────────────────
# MafiaLife — Environment Variables
#
# LOCAL DEVELOPMENT:
#   Copy this file to .env.local (git-ignored) and fill in values.
#   Run: cp .env.example .env.local
#
# VERCEL:
#   Add these as Environment Variables in:
#   Vercel Dashboard → Project Settings → Environment Variables
#   Mark VITE_* variables as "All Environments"
#   Mark SUPABASE_SERVICE_ROLE_KEY as "Production + Preview" only
# ─────────────────────────────────────────────────────────────

# ── Required: Supabase Project URL ────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# ── Required: Supabase Anon Key ───────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API → anon public
# Safe to expose to the browser (used in Vite frontend build)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Optional: Service Role Key (server-side only) ─────────────
# Found in: Supabase Dashboard → Project Settings → API → service_role
# NEVER expose to the browser — only use in scripts/migrations
# Required for: seed scripts, admin API calls
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Optional: Override for local Supabase (supabase start) ────
# Uncomment when running local Supabase instance:
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=<your-local-anon-key-from-supabase-status>

# ── Notes ─────────────────────────────────────────────────────
# If VITE_SUPABASE_URL is missing or set to the placeholder value,
# the app runs in MOCK MODE: all data is in-memory, auth is bypassed,
# and the full prototype is accessible without a real Supabase project.
